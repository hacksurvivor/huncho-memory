PATHMARK_STORE_DIR=~/.pathmark/memory
PATHMARK_MAX_SEARCH_RESULTS=12
# client = MCP client synthesizes from returned context.
# command = PATHMARK_CHAT_COMMAND receives prompt on stdin and returns answer on stdout.
# codex = use local Codex CLI subscription/auth bridge.
PATHMARK_SYNTHESIS_PROVIDER=client

# PATHMARK_CHAT_COMMAND=your-ai-cli --model your-model
# PATHMARK_CODEX_COMMAND=codex
# PATHMARK_CODEX_MODEL=gpt-5.5
# PATHMARK_CHAT_TIMEOUT_MS=120000
