HUNCHO_STORE_DIR=~/.huncho/memory
HUNCHO_MAX_SEARCH_RESULTS=12
# client = MCP client synthesizes from returned context.
# command = HUNCHO_CHAT_COMMAND receives prompt on stdin and returns answer on stdout.
# codex = use local Codex CLI subscription/auth bridge.
HUNCHO_SYNTHESIS_PROVIDER=client

# HUNCHO_CHAT_COMMAND=your-ai-cli --model your-model
# HUNCHO_CODEX_COMMAND=codex
# HUNCHO_CODEX_MODEL=gpt-5.5
# HUNCHO_CHAT_TIMEOUT_MS=120000
